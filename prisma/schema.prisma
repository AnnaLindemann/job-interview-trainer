generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum InputMode {
  TEXT
  VOICE
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  practiceSessions   PracticeSession[]
  practicedQuestions PracticedQuestion[]
}

model Question {
  id              String     @id @default(cuid())
  questionKey     String
  roleSlug        String
  topicSlug       String
  language        String
  difficulty      Difficulty
  questionText    String
  referenceAnswer String
  keyPoints       Json
  tags            Json?
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())

  @@unique([roleSlug, topicSlug, language, questionKey])
  @@index([roleSlug, topicSlug, language])
  @@index([isActive])
}

model PracticeSession {
  id        String    @id @default(cuid())
  userId    String
  roleSlug  String
  topicSlug String
  language  String
  startedAt DateTime  @default(now())
  endedAt   DateTime?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  attempts Attempt[]

  @@index([userId])
  @@index([topicSlug, language])
}

model Attempt {
  id                      String    @id @default(cuid())
  sessionId               String
  questionKey             String
  questionTextSnapshot    String
  referenceAnswerSnapshot String
  roleSlug                String
  topicSlug               String
  language                String
  difficulty              Difficulty
  inputMode               InputMode
  rawTranscript           String?
  finalAnswer             String
  usedVoice               Boolean   @default(false)
  feedbackJson            Json?
  technicalScore          Int?
  grammarScore            Int?
  createdAt               DateTime  @default(now())

  session PracticeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([questionKey])
  @@index([topicSlug, language])
  @@index([createdAt])
  @@index([usedVoice])
}

model PracticedQuestion {
  id                      String     @id @default(cuid())
  userId                  String
  questionKey             String
  questionTextSnapshot    String
  referenceAnswerSnapshot String
  roleSlug                String
  topicSlug               String
  language                String
  difficulty              Difficulty
  addedAt                 DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleSlug, topicSlug, language, questionKey])
  @@index([userId, addedAt])
  @@index([topicSlug, language])
  @@index([questionKey])
}

model LlmUsageLog {
  id               String   @id @default(cuid())
  feature          String
  model            String
  promptVersion    String?
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  estimatedCostUsd Decimal  @db.Decimal(12, 8)
  latencyMs        Int?
  status           String
  sessionId        String?
  questionId       String?
  attemptId        String?
  createdAt        DateTime @default(now())
}